@startuml
title Devil - Сообщения и чтение
left to right direction
skinparam shadowing false
skinparam backgroundColor #ffffff
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam defaultTextAlignment center
skinparam nodesep 45
skinparam ranksep 55
skinparam roundcorner 10
skinparam ArrowColor #687385
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam class {
  BorderColor #9fb0c7
  BackgroundColor #ffffff
  FontColor #1f2937
}
skinparam package {
  BorderColor #c8d0db
  BackgroundColor #f7f9fc
  FontColor #1f2937
}

package "Контекст сообщений" {
  class "Пользователь\nUser" as User {
    +id
    +username
  }

  class "Комната\nRoom" as Room {
    +id
    +kind
  }
}

package "Сообщения" {
  class "Сообщение\nMessage" as Message {
    +id
    +message_content
    +edited_at
    +is_deleted
  }

  class "Реакция\nReaction" as Reaction {
    +emoji
  }

  class "Вложение\nMessageAttachment" as Attachment {
    +original_filename
    +content_type
    +file_size
  }

  class "Черновая загрузка\nMessageAttachmentUpload" as Upload {
    +id
    +status
    +received_bytes
  }

  class "Последнее прочтение\nMessageReadState" as ReadState {
    +last_read_at
  }

  class "Точное прочтение\nMessageReadReceipt" as Receipt {
    +read_at
  }
}

Room -[hidden]right-> Message
Message -[hidden]down-> Reaction
Reaction -[hidden]right-> Attachment
Attachment -[hidden]right-> Upload
Upload -[hidden]right-> ReadState
ReadState -[hidden]down-> Receipt

Message "*" --> "1" Room : находится в комнате
Message "*" --> "0..1" User : автор
Message "0..*" --> "0..1" Message : ответ на

Reaction "*" --> "1" Message : реакция
Reaction "*" --> "1" User : поставил

Attachment "*" --> "1" Message : файлы сообщения
Upload "*" --> "1" Room : загружается в комнату
Upload "*" --> "1" User : загружает

ReadState "*" --> "1" Room : комната
ReadState "*" --> "1" User : пользователь
ReadState "*" --> "0..1" Message : последняя прочитанная

Receipt "*" --> "1" Message : прочитал сообщение
Receipt "*" --> "1" User : кто прочитал
@enduml
