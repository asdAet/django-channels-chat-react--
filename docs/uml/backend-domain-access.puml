@startuml
title Devils Resting - Пользователи и доступ
left to right direction
skinparam shadowing false
skinparam backgroundColor #ffffff
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam defaultTextAlignment center
skinparam nodesep 45
skinparam ranksep 55
skinparam roundcorner 10
skinparam ArrowColor #687385
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam package {
  BorderColor #c8d0db
  BackgroundColor #f7f9fc
  FontColor #1f2937
}
skinparam class {
  BorderColor #9fb0c7
  BackgroundColor #ffffff
  FontColor #1f2937
}

package "Пользователь" {
  class "Пользователь\nUser" as User {
    +id
    +username
  }

  class "Профиль\nProfile" as Profile {
    +name
    +bio
  }

  class "Ядро идентичности\nUserIdentityCore" as IdentityCore {
    +public_id
  }

  class "Логин\nLoginIdentity" as LoginIdentity {
    +login_normalized
  }

  class "Email\nEmailIdentity" as EmailIdentity {
    +email_normalized
  }

  class "OAuth\nOAuthIdentity" as OAuthIdentity {
    +provider
    +provider_user_id
  }

  class "Публичный адрес\nPublicHandle" as PublicHandle {
    +handle
  }

  class "Бакет лимитов\nSecurityRateLimitBucket" as RateBucket {
    +scope_key
    +reset_at
  }
}

package "Комнаты и права" {
  class "Комната\nRoom" as Room {
    +id
    +kind
    +is_public
  }

  class "Роль\nRole" as Role {
    +name
    +position
    +permissions
  }

  class "Участие\nMembership" as Membership {
    +nickname
    +is_banned
    +muted_until
  }

  class "Переопределение прав\nPermissionOverride" as Override {
    +allow
    +deny
  }

  class "Дружба\nFriendship" as Friendship {
    +status
  }
}

User -[hidden]down-> Room
Room -[hidden]right-> Role
Role -[hidden]right-> Membership
Membership -[hidden]right-> Override

User "1" -- "1" Profile : профиль
User "1" -- "0..1" IdentityCore : публичный id
User "1" -- "0..1" LoginIdentity : вход по логину
User "1" -- "0..1" EmailIdentity : email
User "1" -- "0..*" OAuthIdentity : внешние провайдеры
PublicHandle "0..1" --> "0..1" User : адрес пользователя
PublicHandle "0..1" --> "0..1" Room : адрес группы
RateBucket ..> User : лимиты безопасности

Role "*" --> "1" Room : роли комнаты
Membership "*" --> "1" Room : членство
Membership "*" --> "1" User : участник
Membership "*" -- "*" Role : назначенные роли
Override "*" --> "1" Room : действует в комнате
Override "*" --> "0..1" Role : целевая роль
Override "*" --> "0..1" User : целевой пользователь

Friendship "*" --> "1" User : отправитель
Friendship "*" --> "1" User : получатель
@enduml
