@startuml
!include _theme.puml
title Devil - Архитектура бэкенда
top to bottom direction

actor "Клиент" as Browser
cloud "Google OAuth" as Google

rectangle "Внешний контур" as Edge {
  node "Nginx\nTLS, static,\nproxy" as Nginx
}

rectangle "Доставка" as Delivery {
  component "HTTP API\n/api/*" as Rest
  component "WebSocket gateway\n/ws/*" as Ws
  component "ASGI routing\nProtocolTypeRouter" as Asgi
}

rectangle "Прикладные домены" as Domain {
  component "Identity\nusers, profile,\nmedia auth" as Identity
  component "Collaboration\nrooms, messages,\nfriends, groups" as Collaboration
  component "Realtime\nchat, presence,\ninbox consumers" as Realtime
  component "Access control\nroles, permissions,\naudit" as Control
}

rectangle "Инфраструктура" as Infra {
  database "PostgreSQL" as Db
  queue "Redis\nchannel layer,\npresence" as Redis
  folder "Media storage\navatars,\nattachments" as Media
  node "Observability\nPrometheus, Grafana,\nLoki, Alertmanager" as Observability
}

Browser --> Nginx : HTTPS / WSS
Nginx --> Rest : /api/*
Nginx --> Ws : /ws/*
Ws --> Asgi : dispatch

Rest --> Identity
Rest --> Collaboration
Rest --> Control
Asgi --> Identity : token / session
Asgi --> Realtime

Identity --> Db
Identity --> Media
Collaboration --> Db
Collaboration --> Media
Realtime --> Redis
Realtime --> Db
Control --> Db

Collaboration ..> Control : permission check
Realtime ..> Control : moderation / audit
Google --> Identity : OAuth token
Observability ..> Rest : health / metrics

legend right
  Основная линия читается сверху вниз:
  клиент -> edge -> delivery -> домены -> инфраструктура.
  Доменные детали вынесены в отдельные class diagrams.
endlegend
@enduml
