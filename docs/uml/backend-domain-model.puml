@startuml
title Devils Resting - Обзор доменной модели бэкенда
top to bottom direction
skinparam shadowing false
skinparam backgroundColor #ffffff
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam wrapWidth 220
skinparam nodesep 45
skinparam ranksep 55
skinparam roundcorner 10
skinparam ArrowColor #687385
skinparam ArrowThickness 1.1
skinparam defaultFontName Arial
skinparam rectangle {
  BorderColor #9fb0c7
  BackgroundColor #ffffff
  FontColor #1f2937
}
skinparam package {
  BorderColor #c8d0db
  BackgroundColor #f7f9fc
  FontColor #1f2937
}
skinparam note {
  BorderColor #d7dee8
  BackgroundColor #fbfcfe
  FontColor #445066
}

package "Домены бэкенда" {
  rectangle "Пользователи и идентичности\nUser, Profile, Identity,\nPublicHandle, rate limits" as UsersDomain
  rectangle "Комнаты и доступ\nRoom, Role, Membership,\nPermissionOverride, Friendship" as AccessDomain
  rectangle "Сообщения\nMessage, Reaction,\nAttachment, ReadState" as MessagingDomain
  rectangle "Групповые расширения\nInviteLink, JoinRequest,\nPinnedMessage" as GroupsDomain
  rectangle "Аудит и операции\nAuditEvent" as AuditDomain
}

UsersDomain -[hidden]right-> AccessDomain
AccessDomain -[hidden]right-> MessagingDomain
MessagingDomain -[hidden]right-> GroupsDomain
GroupsDomain -[hidden]right-> AuditDomain

UsersDomain --> AccessDomain : пользователь входит в комнату\nи получает права
AccessDomain --> MessagingDomain : доступ управляет чтением\nи отправкой сообщений
AccessDomain --> GroupsDomain : группы строятся поверх Room\nи Membership
MessagingDomain --> GroupsDomain : сообщения можно закреплять
UsersDomain --> AuditDomain : действия пользователя\nфиксируются в аудите
MessagingDomain --> AuditDomain : важные операции\nпишут события аудита
GroupsDomain --> AuditDomain : админские действия групп\nфиксируются в аудите

note bottom of UsersDomain
Подробные схемы вынесены отдельно,
чтобы избежать перегруженной диаграммы.
end note
@enduml
