@startuml
!include _theme.puml
title Devil - Карта пользовательских сценариев
left to right direction

actor "Гость" as Guest
actor "Пользователь" as User
actor "Модератор" as Moderator
actor "Владелец группы" as Owner
actor "Администратор" as Admin
actor "Наблюдаемость" as Monitoring

Moderator --|> User
Owner --|> Moderator
Admin --|> User

rectangle "Devil" {
  package "Вход и доступ" as PAuth {
    usecase "Читать публичный чат" as UC_PublicRead
    usecase "Создать аккаунт\nили войти" as UC_Auth
  }

  package "Личное общение" as PChat {
    usecase "Открыть чат" as UC_OpenChat
    usecase "Отправлять сообщения\nи вложения" as UC_Message
    usecase "Получать realtime\nи read state" as UC_Realtime
  }

  package "Группы" as PGroups {
    usecase "Вступать в группу\nили выходить" as UC_Membership
    usecase "Управлять группой" as UC_GroupAdmin
    usecase "Модерировать участников" as UC_Moderation
  }

  package "Эксплуатация" as POps {
    usecase "Просматривать аудит" as UC_Audit
    usecase "Собирать health\nи метрики" as UC_Metrics
  }
}

Guest --> UC_PublicRead
Guest --> UC_Auth
User --> UC_OpenChat
User --> UC_Message
User --> UC_Realtime
User --> UC_Membership
Moderator --> UC_Moderation
Owner --> UC_GroupAdmin
Admin --> UC_Audit
Monitoring --> UC_Metrics

UC_Auth .> UC_OpenChat : открывает доступ
UC_OpenChat .> UC_Message : выбирает room
UC_Message .> UC_Realtime : синхронизируется
UC_GroupAdmin .> UC_Moderation : настраивает правила
UC_Moderation .> UC_Audit : фиксируется

legend right
  Слайд показывает только крупные сценарии,
  без детализации экранов и внутренних API.
  Его задача - объяснить границы продукта.
endlegend
@enduml
