{
  "include": ["backend"],
  "exclude": [
    "**/node_modules",
    "**/node_modules/**",
    "**/.*",
    "**/.*/**",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.venv",
    "**/venv",
    "**/migrations",
    "backend/tmp_test_temp",
    "backend/tmp_test_temp/**"
  ],
  "venvPath": "backend",
  "venv": ".venv",
  "executionEnvironments": [
    {
      "root": "backend"
    }
  ],
  "typeCheckingMode": "standard",
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none"
}
