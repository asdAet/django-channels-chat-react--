{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "prepare:custom-emoji": "node ./scripts/generate-custom-emoji-manifest.mjs",
        "ensure:rollup-native": "node ./scripts/ensure-rollup-native.mjs",
        "ensure:playwright-browsers": "node ./scripts/ensure-playwright-browsers.mjs",
        "dev": "npm run prepare:custom-emoji && npm run ensure:rollup-native && vite",
        "build": "npm run prepare:custom-emoji && npm run ensure:rollup-native && tsc -b && vite build",
        "lint": "eslint .",
        "lint:css": "stylelint \"src/**/*.css\"",
        "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
        "preview": "npm run prepare:custom-emoji && npm run ensure:rollup-native && vite preview",
        "test": "npm run test:unit",
        "test:unit": "npm run prepare:custom-emoji && npm run ensure:rollup-native && vitest run",
        "test:coverage": "npm run prepare:custom-emoji && npm run ensure:rollup-native && vitest run --coverage",
        "test:e2e": "npm run ensure:playwright-browsers && playwright test",
        "check:dto-boundary": "node ./scripts/check-dto-boundary.mjs"
    },
    "dependencies": {
        "axios": "^1.13.5",
        "fflate": "^0.8.2",
        "lottie-web": "^5.13.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-easy-crop": "^5.5.6",
        "react-router-dom": "^6.30.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@playwright/test": "^1.51.1",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "@vitest/coverage-v8": "^2.1.9",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.1",
        "eslint-plugin-css-modules": "^2.12.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^16.5.0",
        "jsdom": "^26.1.0",
        "msw": "^2.11.6",
        "stylelint": "^17.4.0",
        "stylelint-config-css-modules": "^4.6.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.4",
        "vite": "^7.2.4",
        "vite-plugin-pwa": "^1.0.4",
        "vitest": "^2.1.9",
        "workbox-cacheable-response": "^7.3.0",
        "workbox-core": "^7.3.0",
        "workbox-expiration": "^7.3.0",
        "workbox-precaching": "^7.3.0",
        "workbox-routing": "^7.3.0",
        "workbox-strategies": "^7.3.0",
        "workbox-window": "^7.3.0"
    }
}
